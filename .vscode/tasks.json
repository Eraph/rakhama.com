{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Hugo Server",
            "type": "shell",
            "command": "hugo",
            "args": [
                "server",
                "-D",
                "--cleanDestinationDir"
            ],
            "problemMatcher": []
        },
        {
            "label": "New Post",
            "type": "shell",
            "command": "hugo new posts/${input:new-post-name};code -r ${workspaceFolder}/content/posts/${input:new-post-name}/index.md",
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "new-post-name",
            "type": "promptString",
            "description": "New Post Name",
            "default": "my-new-post"
        }
    ]
}